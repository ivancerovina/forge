{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ivancerovina/forge/raw/master/internal/config/forgerc.schema.json",
  "title": "Forge Project Configuration",
  "description": "Configuration file for a forge-managed project (.forgerc.json)",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the JSON Schema for editor validation and autocompletion"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable project name"
    },
    "description": {
      "type": "string",
      "description": "Project description"
    },
    "code": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$",
      "description": "Project code used for domain generation (letters, numbers, hyphens; cannot start or end with hyphen)"
    },
    "environment": {
      "type": "object",
      "description": "Environment and service configuration",
      "properties": {
        "compose_file": {
          "type": "string",
          "description": "Path to Docker Compose file (relative to project dir). If omitted, auto-detected."
        },
        "alias": {
          "description": "Service alias definitions for Traefik routing. Array format (preferred) or legacy map format.",
          "oneOf": [
            {
              "type": "array",
              "description": "Array of alias entries (preferred format)",
              "items": {
                "type": "object",
                "required": ["port"],
                "oneOf": [
                  { "required": ["container"] },
                  { "required": ["service"] }
                ],
                "properties": {
                  "container": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
                    "description": "Docker container name (container_name or service name from compose file)"
                  },
                  "service": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
                    "description": "Deprecated — use 'container' instead",
                    "deprecated": true
                  },
                  "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "Service port"
                  },
                  "alias": {
                    "type": ["string", "null"],
                    "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$",
                    "description": "Subdomain prefix. null or omitted = index domain (<code>.test)"
                  },
                  "path": {
                    "type": "string",
                    "pattern": "^/[a-zA-Z0-9/_-]+$",
                    "description": "Path prefix for Traefik routing (e.g. /api). Must start with /"
                  },
                  "forward_pathname": {
                    "type": "boolean",
                    "default": false,
                    "description": "Forward path prefix to backend as-is (default false = strip prefix before forwarding)"
                  },
                  "target_path": {
                    "type": "string",
                    "pattern": "^/[a-zA-Z0-9/_-]+$",
                    "description": "Backend target path appended to the service URL (e.g. /test)"
                  },
                  "https": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable HTTPS (default true). Set false for HTTP only"
                  },
                  "cloudflare": {
                    "type": "boolean",
                    "default": false,
                    "description": "Also create a public Traefik router via Cloudflare tunnel"
                  }
                },
                "additionalProperties": false
              }
            },
            {
              "type": "object",
              "description": "Legacy map format (keys are service names). Automatically migrated to array format on write.",
              "additionalProperties": {
                "type": "object",
                "required": ["port"],
                "properties": {
                  "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "Service port"
                  },
                  "alias": {
                    "type": ["string", "null"],
                    "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$",
                    "description": "Subdomain prefix. null or omitted = index domain (<code>.test)"
                  },
                  "path": {
                    "type": "string",
                    "pattern": "^/[a-zA-Z0-9/_-]+$",
                    "description": "Path prefix for Traefik routing (e.g. /api). Must start with /"
                  },
                  "forward_pathname": {
                    "type": "boolean",
                    "default": false,
                    "description": "Forward path prefix to backend as-is (default false = strip prefix before forwarding)"
                  },
                  "target_path": {
                    "type": "string",
                    "pattern": "^/[a-zA-Z0-9/_-]+$",
                    "description": "Backend target path appended to the service URL (e.g. /test)"
                  },
                  "https": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable HTTPS (default true). Set false for HTTP only"
                  },
                  "cloudflare": {
                    "type": "boolean",
                    "default": false,
                    "description": "Also create a public Traefik router via Cloudflare tunnel"
                  }
                },
                "additionalProperties": false
              }
            }
          ]
        },
      },
      "additionalProperties": false
    }
  },
  "required": ["name", "code", "environment"],
  "additionalProperties": false
}
